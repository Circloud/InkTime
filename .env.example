# Photo library path
IMAGE_DIR=./test

# SQLite database path
DB_PATH=./photos.db

# VLM API configuration
API_URL=http://127.0.0.1:1234/v1/chat/completions
MODEL_NAME=qwen3-vl-32b-instruct
# API_KEY=your_api_key_here

# Processing limits
# BATCH_LIMIT=100  # Uncomment to limit photos per run (default: unlimited)
TIMEOUT=600
VLM_MAX_LONG_EDGE=2560

# City resolution
WORLD_CITIES_CSV=./data/world_cities_zh.csv
CITY_GRID_DEG=1.0
CITY_MAX_DISTANCE_KM=80.0

# Home location (for travel detection)
HOME_LAT=22.543096
HOME_LON=114.057865
HOME_RADIUS_KM=60.0

# Selection criteria
MEMORY_THRESHOLD=70.0
DAILY_PHOTO_QUANTITY=5
